{
  "manifest_version": 3,
  "name": "YouNote Transcript Fetcher",
  "version": "1.1.0",
  "description": "Fetches YouTube transcripts using the client's IP to avoid server-side blocking. Works with the YouNote frontend.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://api.ipify.org/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "http://localhost:*/*",
      "https://*.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouNote Transcript Fetcher"
  },
  "icons": {
    "16": "icons/icon-16.png"
  }
}
